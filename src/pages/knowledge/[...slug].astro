---
import KnowledgeLayout from '../../layouts/KnowledgeLayout.astro';
import { getKnowledgePages, getPageBySlug } from '../../lib/content';
import { renderMarkdown } from '../../lib/markdown';

export const prerender = true;

export function getStaticPaths() {
  return getKnowledgePages().map((page) => ({
    params: { slug: page.slug },
  }));
}

const slug = Astro.params.slug;
const page = typeof slug === 'string' ? getPageBySlug(slug) : undefined;

if (!page) {
  return new Response('Not found', {
    status: 404,
    headers: {
      'Content-Type': 'text/plain; charset=utf-8',
    },
  });
}

const html = renderMarkdown(page.body);
---

<KnowledgeLayout page={page} html={html} />
