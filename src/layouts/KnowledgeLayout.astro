---
import BaseLayout from './BaseLayout.astro';
import type { KnowledgePage } from '../lib/content';
import { resolveRawAsset } from '../lib/content';
import { kindLabels } from '../lib/taxonomy';

interface Props {
  page: KnowledgePage;
  html: string;
}

const { page, html } = Astro.props;
const sources = page.sources.map((source) => ({
  ...source,
  asset: resolveRawAsset(source.target),
}));
const visibleSources = sources.filter((source) => source.asset);

function sourceLabel(label: string): string {
  return label.replace(/^raw\//, '');
}
---

<BaseLayout title={page.title} description={page.description}>
  <article class="knowledge-page">
    <nav class="breadcrumb" aria-label="面包屑">
      <a href="/traditional/">传统页面</a>
      <span>/</span>
      <a href={`/${page.kind}/`}>{kindLabels[page.kind]}</a>
    </nav>

    <header class="article-header">
      <span class="kind-badge">{kindLabels[page.kind]}</span>
      <h1>{page.title}</h1>
      {page.description && <p class="lead">{page.description}</p>}
    </header>

    <div class="prose" set:html={html} />

    {visibleSources.length > 0 && (
    <aside class="related-grid" aria-label="参考资料">
      <section>
        <h2>参考资料</h2>
        <ul>
          {visibleSources.map((source) => (
            <li>
              <a href={source.asset!.url} target="_blank" rel="noopener noreferrer">{sourceLabel(source.label)}</a>
            </li>
          ))}
        </ul>
      </section>
    </aside>
    )}
  </article>
</BaseLayout>
