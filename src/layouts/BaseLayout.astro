---
import '../styles/global.css';
import { createSearchItems } from '../lib/content';
import { withBase, withoutBase } from '../lib/sitePaths';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ISP 图像调试个人知识库' } = Astro.props;
const pathname = withoutBase(Astro.url.pathname);
const searchItems = createSearchItems();
const navItems = [
  { href: '/traditional/', label: '传统页面', icon: 'home' },
  { href: '/ask/', label: '问知识库', icon: 'ask' },
  { href: '/platforms/', label: '平台', icon: 'platforms' },
  { href: '/modules/', label: '功能模块', icon: 'modules' },
  { href: '/issues/', label: '问题排查', icon: 'issues' },
  { href: '/workflows/', label: '调试流程', icon: 'workflows' },
  { href: '/tools/', label: '调试工具', icon: 'tools' },
];

const quickLinks = [
  { href: '/knowledge/wiki/indexes/ISP调试知识库导航/', label: '总导航' },
  { href: '/knowledge/wiki/indexes/问题分类索引/', label: '问题分类' },
  { href: '/knowledge/wiki/indexes/ISX031_索引/', label: 'ISX031' },
  { href: '/knowledge/wiki/indexes/SC121AT_索引/', label: 'SC121AT' },
  { href: '/knowledge/wiki/indexes/SC361AT_索引/', label: 'SC361AT' },
  { href: '/knowledge/wiki/indexes/GW5_索引/', label: 'GW5' },
  { href: '/knowledge/wiki/indexes/资料来源索引/', label: '资料来源' },
];

const icons: Record<string, string> = {
  home: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.5 10.7 12 4l8.5 6.7v8.1a1.7 1.7 0 0 1-1.7 1.7h-4.1v-5.8H9.3v5.8H5.2a1.7 1.7 0 0 1-1.7-1.7v-8.1Z"/><path d="M9.3 20.5v-5.8h5.4v5.8"/></svg>',
  ask: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 5.8A2.8 2.8 0 0 1 7.8 3h8.4A2.8 2.8 0 0 1 19 5.8v6.4a2.8 2.8 0 0 1-2.8 2.8h-4.9L7 19v-4H5.8A2.8 2.8 0 0 1 3 12.2V5.8Z"/><path d="M8 8h8M8 11h5"/></svg>',
  platforms: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="5" width="16" height="12" rx="2"/><path d="M9 21h6M12 17v4"/></svg>',
  modules: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="4" y="4" width="7" height="7" rx="1.5"/><rect x="13" y="4" width="7" height="7" rx="1.5"/><rect x="4" y="13" width="7" height="7" rx="1.5"/><rect x="13" y="13" width="7" height="7" rx="1.5"/></svg>',
  issues: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3.5 21 19H3l9-15.5Z"/><path d="M12 9v4M12 16.7h.01"/></svg>',
  workflows: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6h5v5H6zM13 13h5v5h-5zM8.5 11v2.5H13"/></svg>',
  tools: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m14.5 5 4.5 4.5-9.8 9.8H4.7v-4.5L14.5 5Z"/><path d="m13 6.5 4.5 4.5"/></svg>',
  search: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6.5"/><path d="m16 16 4 4"/></svg>',
  sun: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2.5v2M12 19.5v2M4.6 4.6 6 6M18 18l1.4 1.4M2.5 12h2M19.5 12h2M4.6 19.4 6 18M18 6l1.4-1.4"/></svg>',
  moon: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.2 14.8A7.7 7.7 0 0 1 9.2 3.8 8.6 8.6 0 1 0 20.2 14.8Z"/></svg>',
};

function isCurrent(href: string) {
  if (href === '/traditional/') return pathname === '/traditional/';
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <script is:inline>
      (() => {
        let storedTheme = '';
        try {
          storedTheme = localStorage.getItem('isp-notes-theme') || '';
        } catch {
          storedTheme = '';
        }
        const systemDark = window.matchMedia?.('(prefers-color-scheme: dark)').matches;
        const theme = storedTheme || (systemDark ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <title>{title} · ISP 知识库</title>
  </head>
  <body>
    <div class="app-frame">
      <aside class="app-sidebar" aria-label="知识库导航">
        <a class="brand" href={withBase('/traditional/')}>
          <span class="brand-mark" aria-hidden="true"></span>
          <span>ISP Notes</span>
        </a>

        <nav class="side-nav" aria-label="主导航">
          {navItems.map((item) => (
            <a class:list={['nav-link', { active: isCurrent(item.href) }]} href={withBase(item.href)}>
              <span class="nav-icon" set:html={icons[item.icon]} />
              <span>{item.label}</span>
            </a>
          ))}
        </nav>

        <div class="quick-links" aria-label="常用入口">
          {quickLinks.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
        </div>

        <div class="sidebar-note">
          <p>持续记录，随时检索，沉淀每一次调试判断。</p>
          <span>ISP 调试笔记本</span>
        </div>

        <footer class="sidebar-footer">
          <p>© 2026 ISP Notes</p>
          <p>图像调试知识库</p>
        </footer>
      </aside>

      <div class="app-main">
        <header class="topbar">
          <div class="global-search" id="globalSearchRoot">
            <span class="search-icon" set:html={icons.search} />
            <input id="globalSearchInput" type="search" placeholder="搜索文章、功能模块和问题..." autocomplete="off" />
            <kbd>Ctrl K</kbd>
            <div class="global-search-panel" id="globalSearchPanel" hidden></div>
          </div>
          <div class="topbar-actions">
            <button class="icon-button theme-toggle" id="themeToggle" type="button" aria-label="切换深浅主题" aria-pressed="false" title="切换深浅主题">
              <span class="theme-icon theme-icon-moon" set:html={icons.moon} />
              <span class="theme-icon theme-icon-sun" set:html={icons.sun} />
            </button>
            <a class="outline-button" href={withBase('/allinai/')}>AllInAI</a>
            <a class="outline-button" href={withBase('/knowledge/wiki/indexes/ISP调试知识库导航/')}>索引</a>
          </div>
        </header>

        <main class="content-area">
          <slot />
        </main>
      </div>
    </div>

    <script is:inline define:vars={{ searchItems }}>
      const searchRoot = document.getElementById('globalSearchRoot');
      const searchInput = document.getElementById('globalSearchInput');
      const searchPanel = document.getElementById('globalSearchPanel');
      const themeToggle = document.getElementById('themeToggle');

      function syncThemeButton() {
        const dark = document.documentElement.dataset.theme === 'dark';
        if (!themeToggle) return;
        themeToggle.setAttribute('aria-pressed', dark ? 'true' : 'false');
        themeToggle.setAttribute('aria-label', dark ? '切换到浅色主题' : '切换到深色主题');
        themeToggle.title = dark ? '切换到浅色主题' : '切换到深色主题';
      }

      themeToggle?.addEventListener('click', () => {
        const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = nextTheme;
        try {
          localStorage.setItem('isp-notes-theme', nextTheme);
        } catch {
          // Theme still changes for this page even if storage is unavailable.
        }
        syncThemeButton();
      });

      syncThemeButton();

      function escapeHtml(value) {
        return value
          .replaceAll('&', '&amp;')
          .replaceAll('<', '&lt;')
          .replaceAll('>', '&gt;')
          .replaceAll('"', '&quot;')
          .replaceAll("'", '&#039;');
      }

      function renderGlobalResults(query) {
        const normalized = query.trim().toLowerCase();
        if (!searchPanel) return;
        if (!normalized) {
          searchPanel.hidden = true;
          searchPanel.innerHTML = '';
          return;
        }

        const matched = searchItems
          .filter((item) => `${item.title} ${item.description} ${item.text}`.toLowerCase().includes(normalized))
          .slice(0, 6);

        searchPanel.hidden = false;
        searchPanel.innerHTML = matched.length
          ? matched.map((item) => `
              <a class="global-search-item" href="${item.url}">
                <strong>${escapeHtml(item.title)}</strong>
                <span>${escapeHtml(item.description || '知识库页面')}</span>
              </a>
            `).join('')
          : '<p class="global-search-empty">没有找到匹配内容</p>';
      }

      searchInput?.addEventListener('input', (event) => renderGlobalResults(event.target.value));
      searchInput?.addEventListener('focus', (event) => renderGlobalResults(event.target.value));
      document.addEventListener('keydown', (event) => {
        if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
          event.preventDefault();
          searchInput?.focus();
        }
      });
      document.addEventListener('click', (event) => {
        if (searchRoot && !searchRoot.contains(event.target)) {
          searchPanel.hidden = true;
        }
      });
    </script>
  </body>
</html>


