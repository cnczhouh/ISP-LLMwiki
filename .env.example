# Path to your Markdown knowledge base.
# Leave unset to use the bundled ./knowledge directory.
KNOWLEDGE_ROOT=./knowledge

# Preferred local setup: MiMo. The Web UI can choose mimo-v2.5 or mimo-v2-flash.
MIMO_API_KEY=replace-with-your-mimo-api-key

# Optional generic OpenAI-compatible chat completions endpoint.
# OpenAI:  https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com/v1
# Local proxy / sub2api: fill in the proxy's /v1-compatible base URL.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=OpenAI-compatible

# Optional speech output. If omitted, the app will try OPENAI_API_KEY / LLM_API_KEY
# for OpenAI-compatible speech, then MIMO_TTS_API_KEY for MiMo speech.
TTS_BASE_URL=https://api.openai.com/v1
TTS_API_KEY=replace-with-your-api-key
TTS_MODEL=gpt-4o-mini-tts
TTS_PROVIDER=OpenAI TTS
TTS_VOICE=alloy
TTS_RESPONSE_FORMAT=mp3

# Optional MiMo speech overrides.
MIMO_TTS_API_KEY=replace-with-your-mimo-api-key
MIMO_TTS_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts
